# Carsena Platform - Environment Variables Template
# Copy this file to .env and fill in the values

# ==========================================
# 1. DATABASE & SUPABASE (Self-Hosted)
# ==========================================
# Schema used: app_carsena (and legacy app_photoapp_core)
SUPABASE_URL=https://your-supabase-instance.com
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-backend
DATABASE_URL=postgresql://user:password@host:port/postgres?schema=app_carsena

# ==========================================
# 2. CLOUDFLARE R2 (Storage & CDN)
# ==========================================
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=fotografia
VITE_R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev

# ==========================================
# 3. PAYMENT INTEGRATION (Asaas)
# ==========================================
ASAAS_API_KEY=$aact_...
ASAAS_ENVIRONMENT=sandbox # or production
ASAAS_WEBHOOK_SECRET=whsec_...

# ==========================================
# 4. EMAIL SERVICE (Resend)
# ==========================================
RESEND_API_KEY=re_...
RESEND_FROM=Carsena <onboarding@resend.dev>

# ==========================================
# 5. GOOGLE WALLET (Tickets/Passes)
# ==========================================
# Used for signing JWTs to allow users to add tickets to their Google Wallet
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_WALLET_ISSUER_ID=your-issuer-id
GOOGLE_WALLET_CLASS_ID=your-class-id

# ==========================================
# 6. APP CONFIGURATION
# ==========================================
PORT=3000
FRONTEND_URL=https://carsena.com.br
VITE_API_URL=http://localhost:3000/api
VITE_SUPABASE_URL=https://your-supabase-instance.com
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_RESEND_API_KEY=re_...
